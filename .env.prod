# =========================================
# FastAPI Application Production Environment
# =========================================

# Security
SECRET_KEY=your-very-secure-secret-key-here-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL=sqlite:///./app_data/test.db

# API Keys
DEEPSEEK_API_KEY=your-deepseek-api-key-goes-here
OPENAI_API_KEY=your-openai-api-key-goes-here

# File Upload Limits
MAX_AVATAR_SIZE=10485760

# CORS Settings
ALLOWED_ORIGINS=http://your-domain.com,https://your-domain.com